# Awesome-MCPs workspace config

# -------------------------
# GitHub MCP
# -------------------------
GITHUB_TOKEN=

# -------------------------
# Google OAuth (shared across Drive/Gmail/Calendar)
# -------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8787/oauth/callback

# Optional: override token cache path (default: .secrets/google-token.json at repo root)
# GOOGLE_TOKEN_PATH=

# -------------------------
# Slack MCP
# -------------------------
SLACK_BOT_TOKEN=

# -------------------------
# Notion MCP
# -------------------------
NOTION_TOKEN=
# NOTION_VERSION=2022-06-28

# -------------------------
# Jira MCP (Cloud)
# -------------------------
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# -------------------------
# Linear MCP
# -------------------------
LINEAR_API_KEY=

# -------------------------
# Asana MCP
# -------------------------
ASANA_TOKEN=

# -------------------------
# Zendesk MCP
# -------------------------
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# -------------------------
# GitLab MCP
# -------------------------
GITLAB_TOKEN=
# GITLAB_BASE_URL=https://gitlab.com

# -------------------------
# Figma MCP
# -------------------------
FIGMA_TOKEN=

# -------------------------
# Salesforce MCP
# -------------------------
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
# SALESFORCE_API_VERSION=v61.0

# -------------------------
# Stripe MCP
# -------------------------
STRIPE_API_KEY=

# -------------------------
# S3 MCP (AWS S3 / R2 / MinIO)
# -------------------------
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# S3_ENDPOINT=
S3_BUCKET=
# S3_FORCE_PATH_STYLE=

# -------------------------
# Postgres MCP
# -------------------------
PG_CONNECTION_STRING=
# PG_SSLMODE=require
# PG_STATEMENT_TIMEOUT_MS=10000


